# Django
SECRET_KEY=generate-a-strong-random-key-here
DEBUG=False
ALLOWED_HOSTS=your-domain.com,your-server-ip

# PostgreSQL
POSTGRES_DB=prod_db
POSTGRES_USER=prod_user
POSTGRES_PASSWORD=change-this-to-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# GitHub (docker-compose.prod.yml에서 이미지 경로용)
GITHUB_REPOSITORY=your-github-username/your-repo-name
